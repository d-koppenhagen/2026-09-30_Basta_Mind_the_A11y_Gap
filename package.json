{
  "name": "mind-the-a11y-gap",
  "type": "module",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "slidev build",
    "dev": "slidev --open",
    "demo:inaccessible100": "npx http-server demos/inaccessible-but-highscore -p 3200",
    "export": "slidev export",
    "keycastr": "open -a KeyCastr",
    "start": "concurrently -n keycastr,slidev,demo:inaccessible100 -c green,blue,yellow \"npm run keycastr\" \"npm run dev\" \"npm run demo:inaccessible100\""
  },
  "dependencies": {
    "@slidev/cli": "^52.17.0",
    "@slidev/theme-default": "^0.25.0",
    "@slidev/theme-seriph": "^0.25.0",
    "slidev-theme-k9n": "workspace:*",
    "slidev-theme-the-unnamed": "^0.0.24",
    "concurrently": "^10.0.3",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  }
}
